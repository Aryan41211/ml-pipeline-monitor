{
  "uid": "pipeline-metrics",
  "title": "Pipeline Metrics",
  "tags": ["ml", "pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Training / Pipeline Duration (p95)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, dataset, model_type) (rate(ml_pipeline_duration_seconds_bucket[5m])))",
          "legendFormat": "{{dataset}} {{model_type}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 9 }
    },
    {
      "type": "timeseries",
      "title": "Pipeline Success / Failure (rate)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (status) (rate(ml_pipeline_runs_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 9 }
    },
    {
      "type": "timeseries",
      "title": "Experiments Created (rate)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (dataset, model_type) (rate(ml_experiments_total[5m]))",
          "legendFormat": "{{dataset}} {{model_type}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Model Registrations / Promotions (rate)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (stage) (rate(ml_models_registered_total[5m]))",
          "legendFormat": "registered {{stage}}",
          "refId": "D"
        },
        {
          "expr": "sum by (from_stage, to_stage, status) (rate(ml_model_promotions_total[5m]))",
          "legendFormat": "promotion {{from_stage}}->{{to_stage}} {{status}}",
          "refId": "E"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 }
    }
  ],
  "annotations": { "list": [] }
}
