{
  "uid": "drift-metrics",
  "title": "Drift Monitoring",
  "tags": ["ml", "drift"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Drift Score (Gauge)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ml_drift_score",
          "legendFormat": "{{dataset}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 9 }
    },
    {
      "type": "timeseries",
      "title": "Drifted Features Count (Gauge)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ml_drift_features_count",
          "legendFormat": "{{dataset}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 9 }
    },
    {
      "type": "timeseries",
      "title": "Drift Detections (rate)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (severity, drift_detected) (rate(ml_drift_detections_total[5m]))",
          "legendFormat": "{{severity}} drift={{drift_detected}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Drift Analysis Latency (p95)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, dataset) (rate(ml_drift_analysis_duration_seconds_bucket[5m])))",
          "legendFormat": "{{dataset}} p95",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 }
    }
  ],
  "annotations": { "list": [] }
}
